{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/app", "destination": "/app.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "app.creativetagger.ai" }], "destination": "/app.html" }
  ],
  "redirects": [
    { "source": "/", "has": [{ "type": "host", "value": "www.creativetagger.ai" }], "destination": "https://creativetagger.ai", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
